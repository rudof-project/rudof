PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX Map: <http://shex.io/extensions/Map/>
prefix : <http://example.org/>


:Person {
  :name    xsd:string    %Map:{ :name %} ;
  :age     xsd:integer ? %Map:{ :age %} ;
  :address @:Address ? ;
}

:Address {
  :name   xsd:string %Map:{ :addressName %} ;
  :city   xsd:string %Map:{ :addressCity %} ;
}