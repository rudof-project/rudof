    fhir:heartbeatPeriod @<unsignedInt>?; 
    fhir:timeout @<unsignedInt>?; 
    fhir:contentType @<code> AND
    	{fhir:v @fhirvs:mimetypes}?; 
    fhir:content @<code> AND
    	{fhir:v @fhirvs:subscription-payload-content}?; 
    fhir:maxCount @<positiveInt>?; 
}

