    fhir:responseId @<id>?; 
    fhir:sourceId @<id>?; 
    fhir:targetId @<id>?; 
    fhir:url @<string>?; 
}

# Links to the FHIR specification
<TestScript.metadata.link> EXTENDS @<BackboneElement> CLOSED {   
    fhir:url @<uri>; 
    fhir:description @<string>?; 
}

# Source inputs to the mapping
<StructureMap.group.rule.source> EXTENDS @<BackboneElement> CLOSED {   
